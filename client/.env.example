# ── API ─────────────────────────────────────────────────────────────────────
# Development  → point to local Express server
#   (Vite proxy in vite.config.js also forwards /api → localhost:8000)
# VITE_API_URL=http://localhost:8000

# Production on Vercel → leave EMPTY so requests go to same-origin /api/* functions
# VITE_API_URL=

# If you run the backend on a separate host (Render / Railway):
# VITE_API_URL=https://your-backend.onrender.com

VITE_API_URL=

# ── Appwrite ──────────────────────────────────────────────────────────────────
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your_appwrite_project_id
VITE_APPWRITE_DATABASE_ID=your_appwrite_database_id
VITE_APPWRITE_WATCHLIST_COLLECTION_ID=watchlist
